{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.merry360x.com"
        }
      ],
      "destination": "https://merry360x.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/index-:hash.js", "destination": "/assets/index-:hash.js" },
    { "source": "/index-:hash.css", "destination": "/assets/index-:hash.css" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/review?action=send-emails",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/hotel-calendar-sync?action=sync-all",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/pawapay-payout-status?syncAll=1&limit=100",
      "schedule": "15 2 * * *"
    }
  ]
}

