# Copy to .env.local and fill in real values.
# Never commit real secrets.

VITE_APP_ENV=development
VITE_APP_NAME=Merry360
VITE_APP_VERSION=1.0.0

# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Cloudinary (client-side unsigned uploads use cloud name + upload preset)
VITE_CLOUDINARY_CLOUD_NAME=YOUR_CLOUD_NAME
VITE_CLOUDINARY_UPLOAD_PRESET=YOUR_UNSIGNED_UPLOAD_PRESET

# Optional feature flags
VITE_ENABLE_AI_CONCIERGE=false
VITE_ENABLE_CRYPTO_PAYMENTS=false
VITE_USE_SUPABASE=true
VITE_USE_MOCK_API=false
VITE_USE_STRIPE=false

# Flutterwave (server-side)
FLW_PUBLIC_KEY=YOUR_FLUTTERWAVE_PUBLIC_KEY
FLW_SECRET_KEY=YOUR_FLUTTERWAVE_SECRET_KEY
FLW_ENCRYPTION_KEY=YOUR_FLUTTERWAVE_ENCRYPTION_KEY
FLW_BASE_URL=https://api.flutterwave.com/v3
FLW_WEBHOOK_SECRET_HASH=YOUR_FLUTTERWAVE_WEBHOOK_SECRET_HASH

# API runtime
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
APP_BASE_URL=http://localhost:5173
